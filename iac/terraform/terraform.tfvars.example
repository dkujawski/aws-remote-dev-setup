region = "us-west-2"
profile = "badassdave"
remote_dev_user_name = "acme-remote-dev"
iam_group_name       = "acme-remote-dev"
iam_policy_name      = "acme-remote-dev"

# EC2 Instance Configuration (Budget-Friendly)
instance_count = 1                    # Number of development instances
instance_type = "t3.micro"           # Most budget-friendly general purpose instance
instance_name_prefix = "dev-instance"
auto_shutdown_hours = 24             # Auto-shutdown after 24 hours
enable_spot_instances = true         # Use Spot instances for maximum cost savings
spot_max_price = ""                  # Leave empty to use current Spot price

# Optional: Override with specific instance ARNs if you have existing instances
# dev_instance_arns = [
#   "arn:aws:ec2:us-east-1:123456789012:instance/i-0123456789abcdef0"
# ]

# GitHub Configuration
github_username = "dkujawski"  # GitHub username for SSH key management
github_email = "your-github-email@example.com"
# Note: SSH keys should be stored in 1Password with these references:
# github_ssh_private_key = "op://Private/github_ssh_private_key/private_key"
# github_ssh_public_key = "op://Private/github_ssh_public_key/public_key"

# session_manager_document_arns = [
#   "arn:aws:ssm:us-east-1::document/AWS-StartSSHSession"
# ]
