region  = "us-west-2"
profile = "remote-dev-admin"

remote_dev_user_name = "acme-remote-dev"
iam_group_name       = "acme-remote-dev"
iam_policy_name      = "acme-remote-dev"

dev_instances = {
  "acme-remote-dev-01" = {
    ami_id        = "ami-0abcdef1234567890"
    instance_type = "t3.large"
    subnet_id     = "subnet-0123456789abcdef0"
    security_group_ids = [
      "sg-0123456789abcdef0"
    ]
    volume_size = 100
    tags = {
      Environment = "dev"
      Owner        = "remote-dev-team"
    }
  }
}

